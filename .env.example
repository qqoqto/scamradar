# === LINE Bot ===
# 從 LINE Developers Console 取得
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# === Claude API ===
# 從 Anthropic Console 取得
# https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# === Database ===
# 本地開發用 docker-compose 內建的 PostgreSQL，不用改
# 部署到 Render/Railway 時，平台會提供 DATABASE_URL
DATABASE_URL=postgresql+asyncpg://scamradar:scamradar@localhost:5432/scamradar

# === Redis ===
# 本地開發用 docker-compose 內建的 Redis
# 部署時使用 Render/Railway 的 Redis 服務
REDIS_URL=redis://localhost:6379/0

# === Google Safe Browsing (選填) ===
# https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_KEY=

# === App Settings ===
DEBUG=true
LOG_LEVEL=INFO
