# ─── ScamRadar 環境變數 ──────────────────────────────────

# LINE Bot（從 LINE Developers Console 取得）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Claude API（從 Anthropic Console 取得）
CLAUDE_API_KEY=

# PostgreSQL（Railway 會自動注入 DATABASE_URL）
DATABASE_URL=postgresql+asyncpg://scamradar:scamradar@localhost:5432/scamradar

# Redis（Railway 會自動注入 REDIS_URL）
REDIS_URL=redis://localhost:6379/0

# Google Safe Browsing（可選）
GOOGLE_SAFE_BROWSING_KEY=

# App 設定
DEBUG=false
LOG_LEVEL=INFO
